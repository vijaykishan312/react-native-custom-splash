        "splash",
        "ios",
        "android",
        "native-module",
        "new-architecture",
        "turbomodule",
        "fabric"
    ],
    "homepage": "https://github.com/vijaykishan312/react-native-custom-splash#readme",
    "bugs": {
        "url": "https://github.com/vijaykishan312/react-native-custom-splash/issues"
    },
    "author": "Vijay Kishan",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vijaykishan312/react-native-custom-splash.git"
    },
    "dependencies": {
        "@expo/config-plugins": "^8.0.0",
        "@expo/image-utils": "^0.5.0"
    },
    "peerDependencies": {
        "react": "*",
        "react-native": "*",
        "expo": "*"
    },
    "devDependencies": {
        "@types/react": "^18.0.0",
        "@types/react-native": "^0.72.0",
        "typescript": "^5.0.0"
    },
    "files": [
        "src/",
        "ios/",
        "android/",
        "plugin/",
        "app.plugin.js",
        "react-native.config.js",
        "react-native-custom-splash.podspec",
        "example/app.json*",
        "example/README.md",
        "README.md",
        "LICENSE",
        "CHANGELOG.md",
        "CONTRIBUTING.md",
        "CODE_OF_CONDUCT.md",
        "SECURITY.md"
